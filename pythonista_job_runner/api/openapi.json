{
  "components": {
    "parameters": {
      "JobId": {
        "in": "path",
        "name": "job_id",
        "required": true,
        "schema": {
          "pattern": "^[^./][^/]*$",
          "type": "string"
        }
      }
    },
    "responses": {
      "Unauthorised": {
        "content": {
          "application/json": {
            "example": {
              "error": "unauthorised"
            },
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Authentication failed"
      },
      "UnknownJob": {
        "content": {
          "application/json": {
            "example": {
              "error": "unknown_job"
            },
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Job not found"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "enum": [
              "ok"
            ],
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "version"
        ],
        "type": "object"
      },
      "JobLimits": {
        "properties": {
          "cpu_count": {
            "type": "integer"
          },
          "cpu_cpulimit_pct": {
            "type": "integer"
          },
          "cpu_limit_mode": {
            "type": "string"
          },
          "cpu_percent": {
            "type": "integer"
          },
          "mem_mb": {
            "type": "integer"
          },
          "threads": {
            "type": "integer"
          },
          "timeout_seconds": {
            "type": "integer"
          }
        },
        "required": [
          "cpu_percent",
          "cpu_limit_mode",
          "cpu_count",
          "cpu_cpulimit_pct",
          "mem_mb",
          "threads",
          "timeout_seconds"
        ],
        "type": "object"
      },
      "JobStatus": {
        "properties": {
          "client_ip": {
            "type": [
              "string",
              "null"
            ]
          },
          "created_utc": {
            "type": "string"
          },
          "delete_requested": {
            "type": "boolean"
          },
          "duration_seconds": {
            "type": [
              "integer",
              "null"
            ]
          },
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "exit_code": {
            "type": [
              "integer",
              "null"
            ]
          },
          "finished_utc": {
            "type": [
              "string",
              "null"
            ]
          },
          "input_sha256": {
            "type": [
              "string",
              "null"
            ]
          },
          "job_id": {
            "type": "string"
          },
          "limits": {
            "$ref": "#/components/schemas/JobLimits"
          },
          "phase": {
            "type": "string"
          },
          "result_filename": {
            "type": "string"
          },
          "runner_version": {
            "type": "string"
          },
          "started_utc": {
            "type": [
              "string",
              "null"
            ]
          },
          "state": {
            "enum": [
              "queued",
              "running",
              "done",
              "error"
            ],
            "type": "string"
          },
          "submitted_by": {
            "$ref": "#/components/schemas/SubmittedBy"
          }
        },
        "required": [
          "job_id",
          "created_utc",
          "state",
          "phase",
          "runner_version",
          "submitted_by",
          "limits",
          "result_filename",
          "delete_requested"
        ],
        "type": "object"
      },
      "PurgeRequest": {
        "additionalProperties": true,
        "properties": {
          "dry_run": {
            "type": "boolean"
          },
          "older_than_hours": {
            "type": "integer"
          },
          "state": {
            "type": "string"
          },
          "states": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "PurgeResponse": {
        "properties": {
          "count": {
            "type": "integer"
          },
          "deleted": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "dry_run": {
            "type": "boolean"
          },
          "ok": {
            "type": "boolean"
          }
        },
        "required": [
          "ok",
          "deleted",
          "count",
          "dry_run"
        ],
        "type": "object"
      },
      "RunAcceptedResponse": {
        "properties": {
          "job_id": {
            "type": "string"
          },
          "jobs_url": {
            "type": "string"
          },
          "result_url": {
            "type": "string"
          },
          "tail_url": {
            "type": "string"
          }
        },
        "required": [
          "job_id",
          "tail_url",
          "result_url",
          "jobs_url"
        ],
        "type": "object"
      },
      "ServiceInfo": {
        "properties": {
          "endpoints": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "service": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "service",
          "version",
          "endpoints"
        ],
        "type": "object"
      },
      "SetupMutationResponse": {
        "additionalProperties": true,
        "properties": {
          "action": {
            "type": "string"
          },
          "error": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "profile_name": {
            "type": "string"
          },
          "setup_status": {
            "$ref": "#/components/schemas/SetupStatusResponse"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "setup_status"
        ],
        "type": "object"
      },
      "SetupStatusResponse": {
        "additionalProperties": true,
        "properties": {
          "blockers": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "config_snippet": {
            "type": "string"
          },
          "next_steps": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "ready_for_example_5": {
            "type": "boolean"
          },
          "ready_state": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "target_profile": {
            "type": "string"
          },
          "target_wheel": {
            "type": "string"
          },
          "warnings": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "ready_for_example_5",
          "ready_state",
          "blockers",
          "next_steps"
        ],
        "type": "object"
      },
      "SubmittedBy": {
        "properties": {
          "display_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": [
              "string",
              "null"
            ]
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "name",
          "display_name"
        ],
        "type": "object"
      },
      "TailResponse": {
        "properties": {
          "offsets": {
            "properties": {
              "stderr_from": {
                "type": "integer"
              },
              "stderr_next": {
                "type": "integer"
              },
              "stderr_size": {
                "type": "integer"
              },
              "stdout_from": {
                "type": "integer"
              },
              "stdout_next": {
                "type": "integer"
              },
              "stdout_size": {
                "type": "integer"
              }
            },
            "type": "object"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "tail": {
            "properties": {
              "stderr": {
                "type": "string"
              },
              "stdout": {
                "type": "string"
              }
            },
            "required": [
              "stdout",
              "stderr"
            ],
            "type": "object"
          }
        },
        "required": [
          "status",
          "tail"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "RunnerToken": {
        "in": "header",
        "name": "X-Runner-Token",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "description": "Machine-readable contract for the direct HTTP API exposed by pythonista_job_runner. This contract is derived from app/http_api_server.py and validated by tests.",
    "title": "Pythonista Job Runner Direct API",
    "version": "0.6.13"
  },
  "openapi": "3.0.3",
  "paths": {
    "/": {
      "get": {
        "description": "Returns JSON service info by default. If Accept prefers HTML, returns Web UI and requires auth.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceInfo"
                }
              },
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Service info JSON or HTML page"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorised"
          }
        },
        "summary": "Service index or Web UI"
      }
    },
    "/cancel/{job_id}": {
      "post": {
        "parameters": [
          {
            "$ref": "#/components/parameters/JobId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "ok"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Cancellation request accepted"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorised"
          }
        },
        "security": [
          {
            "RunnerToken": []
          }
        ],
        "summary": "Cancel a job"
      }
    },
    "/health": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Service health"
          }
        },
        "summary": "Health check"
      }
    },
    "/index.html": {
      "get": {
        "responses": {
          "200": {
            "description": "Service info JSON or HTML page"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorised"
          }
        },
        "summary": "Service index or Web UI"
      }
    },
    "/info.json": {
