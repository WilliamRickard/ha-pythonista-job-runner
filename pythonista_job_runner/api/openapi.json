                      "type": "boolean"
                    }
                  },
                  "required": [
                    "ok"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Delete request result"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorised"
          }
        },
        "security": [
          {
            "RunnerToken": []
          }
        ],
        "summary": "Delete a job"
      }
    },
    "/job/{job_id}.json": {
